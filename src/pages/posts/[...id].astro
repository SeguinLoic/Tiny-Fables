---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Image } from "astro:assets";

import BaseLayout from "@/layouts/BaseLayout.astro";

import { formatDate } from "@/lib/util";

interface Props {
  entry: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout>
  <div>
    {
      entry.data.image && (
        <Image
          src={entry.data.image}
          alt={entry.data.imageAlt || ""}
          class="mb-12 h-auto w-full"
          draggable="false"
          loading="eager"
        />
      )
    }
    <h1 class="text-[36px] leading-snug font-bold text-balance text-black dark:text-white">
      {entry.data.title}
    </h1>
    <span>{entry.data.description}</span>
    <p class="text-muted-text dark:text-dark-muted-text mt-3">
      {formatDate(entry.data.publicationDate)}
    </p>
    <div class="prose dark:prose-invert prose-neutral">
      <hr class="my-8" />
      <div>
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>
