---
import { SOCIAL_LINKS } from "@/siteConfig";

import ExternalLink from "@/components/ExternalLink.astro";
---

<section>
  <div class="prose dark:prose-invert prose-neutral mb-3">
    <h2>Contact</h2>
  </div>
  <ul class="grid list-none gap-4 p-0">
    {
      Object.values(SOCIAL_LINKS).map((socialLink) => {
        return (
          <ExternalLink href={socialLink.href}>{socialLink.label}</ExternalLink>
        );
      })
    }
  </ul>
</section>
