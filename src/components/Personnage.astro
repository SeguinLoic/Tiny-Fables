---
import type { CollectionEntry } from "astro:content";
import { Image } from 'astro:assets';

interface Props {
  personnage: CollectionEntry<"personnages">;
}

const { personnage } = Astro.props;
---

<li>
    <Image src={personnage.data.image.source} alt={personnage.data.image.alt} width="90px" />
    <span class="name">{personnage.data.name}</span>
    <div>
        <span>level: {personnage.data.level}</span>
        <span>Pips: {personnage.data.pips}</span>
    </div>
    <table>
        <tbody>
            <tr>
                <th scope="row">Strength</th>
                <td>{personnage.data.stats.str}</td>
            </tr>
            <tr>
                <th scope="row">Dexterity</th>
                <td>{personnage.data.stats.dex}</td>
            </tr>
            <tr>
                <th scope="row">Will power</th>
                <td>{personnage.data.stats.will}</td>
            </tr>
            <tr>
                <th scope="row">Life</th>
                <td>{personnage.data.stats.life}</td>
            </tr>
        </tbody>
    </table>
</li>


<style>
li {
    width: 50%;
    padding: 16px;
}
span.name {
    font-size: 1.3em;
    font-weight: 700;
}
table tbody tr {
    border: 1px solid;
}
table tbody tr th {
    border: 1px solid;
    padding: 1px 8px;
    text-align: left;
    font-weight: 500;
}
table tbody tr td {
    padding: 1px 8px;
}
</style>