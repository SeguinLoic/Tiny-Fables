---
import { NAV_LINKS, SITE } from "@/siteConfig.ts";
---

<header
  class="mx-auto flex max-w-screen-sm flex-wrap items-center justify-between p-3 pb-8 sm:p-6"
>
  <a
    href="/"
    class="text-lg font-semibold text-black sm:text-xl dark:text-white"
    >{SITE.title}</a
  >
  <nav>
    <ul class="flex list-none items-center gap-2 p-0 sm:gap-3">
      {
        Object.values(NAV_LINKS).map((navItem) => {
          return (
            <li>
              <a href={navItem.path} class="link">
                {navItem.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
