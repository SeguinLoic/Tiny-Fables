---
import { type CollectionEntry } from "astro:content";
import { SITE } from "@/siteConfig";

interface Props {
  entry: CollectionEntry<"posts">;
}

const { entry } = Astro.props;

const postTitle = entry.data.title || SITE.title;
const postDescription = entry.data.description || SITE.description;
const base = SITE.href || Astro.url.origin;
const ogImage = new URL("./og.jpg", base);
---

<title>{`${postTitle} | ${SITE.title}`}</title>
<meta name="title" content={`${postTitle} | ${SITE.title}`} />
<meta name="description" content={postDescription} />
<link rel="canonical" href={new URL(Astro.url.pathname, base)} />

<meta property="og:title" content={postTitle} />
<meta property="og:description" content={postDescription} />
<meta
  property="og:image"
  content={entry?.data?.image?.src
    ? `${base}${entry.data.image.src}`
    : ogImage}
/>
<meta property="og:image:alt" content={postTitle} />
<meta property="og:type" content="article" />
<meta property="og:locale" content={SITE.locale} />

<meta name="twitter:title" content={postTitle} />
<meta name="twitter:description" content={postDescription} />
<meta
  property="twitter:image"
  content={entry?.data?.image?.src
    ? `${base}${entry.data.image.src}`
    : ogImage}
/>
<meta name="twitter:image:alt" content={postTitle} />
<meta name="twitter:card" content="summary_large_image" />

{
  entry?.data.tags &&
    entry.data.tags.map((tag: string) => {
      return <meta property="article:tag" content={tag} />;
    })
}
